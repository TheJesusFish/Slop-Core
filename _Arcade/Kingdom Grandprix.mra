<misterromdescription>
    <name>Kingdom Grandprix</name>
    <setname>kingdmgp</setname>
    <rbf>Raizing</rbf>
    <mameversion>0270</mameversion>
    <year>1994</year>
    <manufacturer>Raizing / Eighting</manufacturer>
    <players>2</players>
    <joystick>8-way</joystick>
    <rotation>Vertical (CCW)</rotation>
    <region>World</region>
    <platform>Toaplan 2</platform>
    <category>Shoot'em up</category>
    <catver>Shooter / Flying Vertical</catver>

    <buttons names="Shot,Bomb,-,Start,Coin,Pause" default="Y,X,B,R,L,Start"/>

    <switches default="00,00,F2">
        <!-- DSW A -->
        <dip name="Free Play" bits="0" ids="Off,On"/>
        <dip name="Screen Flip" bits="1" ids="Normal,Invert"/>
        <dip name="Test Mode" bits="2" ids="Off,On"/>
        <dip name="Advertise Sound" bits="3" ids="On,Off"/>
        <dip name="Coin A" bits="4,5" ids="1/1,1/2,2/1,2/3"/>
        <dip name="Coin B" bits="6,7" ids="1/1,1/2,2/1,2/3"/>
        <!-- DSW B -->
        <dip name="Difficulty" bits="8,9" ids="Normal,Easy,Hard,Very Hard"/>
        <dip name="Extend" bits="10,11" ids="300k(E),200k/500k,200k,None"/>
        <dip name="Number of Heroes" bits="12,13" ids="3,5,2,1"/>
        <dip name="No Death/Stop Mode" bits="14" ids="Off,On"/>
        <dip name="Continue Play" bits="15" ids="On,Off"/>
        <!-- JMPR -->
        <!-- Japan requires the shippumd text ROM; using it with kingdmgp corrupts the game text. -->
        <dip name="Region" bits="16,19" ids="EU,USA,SEA,CHN,KOR,HK,TWN" values="4,2,6,8,10,12,14"/>
    </switches>

    <rom index="0" zip="kingdmgp.zip" md5="None" address="0x30000000">
        <part>02</part>
        <!-- maincpu - starts at 0x0 -->
        <interleave output="16">
            <part name="ma02rom1.bin" crc="a678b149" map="01"/>
            <part name="ma02rom0.bin" crc="f226a212" map="10"/>
        </interleave>
        <!-- audiocpu - starts at 0x100000 -->
        <part name="ma02rom2.bin" crc="dde8a57e"/>
        <!-- gp9001_0 - starts at 0x110000 -->
        <interleave output="16">
            <part name="ma02rom3.bin" crc="0e797142" map="01"/>
            <part name="ma02rom4.bin" crc="72a6fa53" map="10"/>
        </interleave>
        <!-- text - starts at 0x510000 -->
        <part name="ma02rom5.eng" crc="8c28460b"/>
        <!-- oki1 - starts at 0x518000 -->
        <part name="ma02rom6.bin" crc="199e7cae"/>
    </rom>

    <!-- Vertical game. Orientation reversed. -->
    <rom index="1">
        <part>05 80</part>
    </rom>

    <rom index="2">
        <part>
            0010  0000  0010  0000  0008  0000  0006  0000
            0004  0000  0002  0000  0000  0000  0000  0000
            0000  0000  0000  0000  0000  0000  0005  0002
            0007  0000  0006  0000  0000  0000  0000  0000
            0000  0000  0000  0000  0000  0000  0000  0000
            0000  0000  004D  0020  0041  0020  0048  0020
            0020  0020  0052  0020  0041  0020  0059  0020
            0020  0020  0052  0020  0041  0020  0049  0020
            0020  0020  004E  0020  0045  0020  0042  0020
            0020  0020  0053  0020  0045  0020  004E  0020
            0020  0020  0000  0000  0000  0000  0000  0000
            0000  0000  0000  0000  0000  0000  0000  0000
            0000  0000  0000  0000  0000  0000  0000  0000
            0000  0000  0000  0000  0000  0000  0000  0000
            0000  0000  0000  0000  0000  0000  0000  0000
            0000  0000  2A30  2A30  2A30  FFFF  FFFF  FFFF
            FFFF  FFFF  FFFF  FFFF  FFFF  FFFF  0000  0000
            0000  0000  0000  0000  5A41  5400  5441  4300
            4D41  5400  4D41  4300  5547  4D00  5347  4D00
            462F  4100  5444  4600  5344  4600  534F  4200
            4745  4E00  5439
        </part>
    </rom>

    <nvram index="2" size="326"/>
</misterromdescription>
