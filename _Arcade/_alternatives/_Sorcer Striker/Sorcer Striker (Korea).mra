<misterromdescription>
    <name>Sorcer Striker (Korea)</name>
    <setname>sstrikerk</setname>
    <rbf>Raizing</rbf>
    <mameversion>0270</mameversion>
    <year>1993</year>
    <manufacturer>Raizing</manufacturer>
    <players>2</players>
    <joystick>8-way</joystick>
    <rotation>Vertical (CCW)</rotation>
    <region>Korea</region>
    <platform>Toaplan 2</platform>
    <category>Shoot'em up</category>
    <catver>Shooter / Flying Vertical</catver>

    <buttons names="Shot,Bomb,-,Start,Coin,Pause" default="Y,X,B,R,L,Start"/>

    <switches default="00,00,F2">
        <!-- DSW A -->
        <dip name="Free Play" bits="0" ids="Off,On"/>
        <dip name="Screen Flip" bits="1" ids="Normal,Reverse"/>
        <dip name="Test Mode" bits="2" ids="Off,On"/>
        <dip name="Advertise Sound" bits="3" ids="On,Off"/>
        <dip name="Coin A" bits="4,5" ids="1/1,1/2,2/1,2/3"/>
        <dip name="Coin B" bits="6,7" ids="1/1,1/2,2/1,2/3"/>
        <!-- DSW B -->
        <dip name="Difficulty" bits="8,9" ids="Normal,Easy,Hard,Very Hard"/>
        <dip name="Extend" bits="10,11" ids="300k(E),200k/500k,200k,None"/>
        <dip name="Number of Heroes" bits="12,13" ids="3,5,2,1"/>
        <dip name="No Death/Stop Mode" bits="14" ids="Off,On"/>
        <dip name="Continue Play" bits="15" ids="On,Off"/>
        <!-- JMPR -->
        <dip name="Region" bits="16,19" ids="JPN,USA,EU,SEA,CHN,KOR,HK,TWN" values="0,2,4,6,8,10,12,14"/>
    </switches>

    <rom index="0" zip="sstrikerk.zip|sstriker.zip" md5="None" address="0x30000000">
        <part>01</part>
        <!-- maincpu - starts at 0x0 -->
        <interleave output="16">
            <part name="ra-ma-01_01.u65" crc="92259f84" map="12"/>
        </interleave>
        <!-- audiocpu - starts at 0x80000 -->
        <part name="ra-ma-01_02.u66" crc="eabfa46d"/>
        <!-- gp9001_0 - starts at 0x90000 -->
        <interleave output="16">
            <part name="ra-ma01-rom2.u2" crc="54e2bd95" map="01"/>
            <part name="ra-ma01-rom3.u1" crc="21cd378f" map="10"/>
        </interleave>
        <!-- text - starts at 0x290000 -->
        <part name="ra-ma-01_05.u81" crc="88b58841"/>
        <!-- oki1 - starts at 0x298000 -->
        <part name="ra-ma01-rom1.u57" crc="6edb2ab8"/>
    </rom>

    <!-- Vertical game. Orientation reversed. -->
    <rom index="1">
        <part>05 80</part>
    </rom>

    <rom index="2">
        <part>
              0065  5000  0065  5000  0042  2000  0034  6000
              0020  1000  0016  3000  0000  0000  0000  0000
              0000  0000  0000  0000  0000  0000  0001  0002
              0000  0001  0003  0000  0000  0000  0000  0000
              0000  0000  0000  0000  0000  0000  0000  0000
              0000  0000  0059  0020  004F  0020  004B  0020
              0020  0020  0059  0020  0041  0020  0053  0020
              0020  0020  005A  0020  005E  0020  005F  0020
              0020  0020  0053  0020  0049  0020  004E  0020
              0020  0020  0062  0020  0061  0020  0060  0020
              0020  0020
        </part>
    </rom>

    <nvram index="2" size="164"/>
</misterromdescription>
