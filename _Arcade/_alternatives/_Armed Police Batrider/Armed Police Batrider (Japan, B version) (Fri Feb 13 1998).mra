<misterromdescription>
    <name>Armed Police Batrider (Japan, B Version) (Fri Feb 13 1998)</name>
    <setname>batriderj</setname>
    <rbf>Raizing</rbf>
    <mameversion>0270</mameversion>
    <year>1998</year>
    <manufacturer>Raizing / Eighting</manufacturer>
    <players>2</players>
    <joystick>8-Way</joystick>
    <rotation>Vertical (CCW)</rotation>
    <region>Japan</region>
    <platform>Toaplan 2</platform>
    <category>Shoot'em up</category>
    <catver>Shooter / Flying Vertical</catver>

    <buttons names="Shot,Bomb,Formation,Start,Coin,Pause" default="Y,X,B,R,L,Start"/>

    <switches default="00,00,E4">
        <!-- DSW A -->
        <dip name="Test Mode" bits="0" ids="Off,On"/>
        <dip name="Starting Coin" bits="1" ids="1,2"/>
        <dip name="Coin 1" bits="2,4" ids="1/1,1/2,1/3,1/4,2/1,3/1,4/1,Free Play"/>
        <dip name="Coin 2" bits="5,7" ids="1/1,1/2,1/3,1/4,2/1,3/1,4/1"/>
        <!-- DSW B -->
        <dip name="Start Rank" bits="8,9" ids="Normal,Easy,Hard,Very Hard"/>
        <dip name="Timer Rank" bits="10,11" ids="Normal,Low,High,Highest"/>
        <dip name="Player Counts" bits="12,13" ids="3,4,2,1"/>
        <dip name="Extra Player" bits="14,15" ids="Every 1500k,Every 1000k,Every 2000k,None"/>
        <!-- DSW C -->
        <dip name="Screen Flip" bits="16" ids="Off,On"/>
        <dip name="Demo Sound" bits="17" ids="On,Off"/>
        <dip name="Stage Edit" bits="18" ids="Off,On"/>
        <dip name="Continue Play" bits="19" ids="Yes,No"/>
        <dip name="Invincible" bits="20" ids="Off,On"/>
        <dip name="Guest Players" bits="21" ids="Off,On"/>
        <dip name="Player Select" bits="22" ids="Off,On"/>
        <dip name="Special Course" bits="23" ids="Off,On"/>
    </switches>

    <rom index="0" zip="batriderj.zip|batrider.zip" md5="None" address="0x30000000">
        <!-- mapper for game 03 - batrider -->
        <part>03</part>
        <!-- maincpu - starts at 0x0 -->
        <interleave output="16">
            <part name="prg0b.u22" crc="4f3fc729" map="01"/>
            <part name="prg1b.u23" crc="8e70b492" map="10"/>
        </interleave>
        <interleave output="16">
            <part name="prg2.u21" crc="bdaa5fbf" map="01"/>
            <part name="prg3.u24" crc="7aa9f941" map="10"/>
        </interleave>
        <!-- audiocpu - starts at 0x200000 -->
        <part name="snd.u77" crc="56682696"/>
        <!-- gp9001_0 - starts at 0x240000 -->
        <interleave output="16">
            <part name="rom-1.bin" crc="0df69ca2" map="01"/>
            <part name="rom-2.bin" crc="1bfea593" map="10"/>
        </interleave>
        <interleave output="16">
            <part name="rom-3.bin" crc="60167d38" map="01"/>
            <part name="rom-4.bin" crc="bee03c94" map="10"/>
        </interleave>
        <!-- oki1 - starts at 0x1240000 -->
        <part name="rom-5.bin" crc="4274daf6"/>
        <!-- oki2 - starts at 0x1340000 -->
        <part name="rom-6.bin" crc="2a1c2426"/>
    </rom>

    <!-- Vertical screen. Orientation reversed. -->
    <rom index="1">
        <part>05 80</part>
    </rom>

